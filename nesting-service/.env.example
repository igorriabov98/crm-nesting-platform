# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database
# Use the existing CRM PostgreSQL database and keep nesting tables in their own schema.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db?schema=nesting

# File storage
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output
MAX_FILE_SIZE_MB=500
UPLOAD_RATE_LIMIT_MAX=100

# CORS - CRM origin
CORS_ORIGIN=http://localhost:3000

# Claude API (PDF parsing phase)
ANTHROPIC_API_KEY=

# OpenRouter AI PDF analysis
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_SETTINGS_ENCRYPTION_KEY=
