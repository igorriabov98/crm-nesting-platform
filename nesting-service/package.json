{
  "name": "nesting-service",
  "version": "1.0.0",
  "description": "Sheet metal nesting microservice",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "worker:step": "tsx src/workers/step-worker.ts",
    "worker:nesting": "tsx src/workers/nesting-worker.ts",
    "brep:dump": "tsx scripts/brep-dump.ts",
    "brep:solids": "tsx scripts/brep-solids.ts",
    "fixtures": "tsx scripts/generate-fixtures.ts",
    "fixtures:phase1": "tsx scripts/generate-fixtures.ts",
    "validate:real": "tsx scripts/validate-real-parts.ts",
    "test:storage-auth": "tsx src/lib/__tests__/test-storage-auth.ts",
    "test:phase0": "tsx src/lib/__tests__/test-dimension-guard.ts && tsx src/lib/__tests__/test-dxf-no-anisotropy.ts && tsx src/lib/__tests__/test-nesting-params.ts && tsx src/lib/__tests__/test-layout-validator.ts",
    "test:phase1": "tsx src/lib/__tests__/test-brep-contour.ts && tsx src/lib/__tests__/test-polygon-utilization.ts && tsx src/lib/__tests__/test-put-guard.ts && tsx src/lib/__tests__/test-phase1-fixture-pipeline.ts",
    "test:phase2": "tsx src/lib/__tests__/test-bend-detector.ts && tsx src/lib/__tests__/test-unfold.ts && tsx src/lib/__tests__/test-unfold-pipeline.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.0.0",
    "@supabase/supabase-js": "^2.50.0",
    "archiver": "^7.0.0",
    "fastify": "^5.0.0",
    "occt-import-js": "^0.0.23",
    "opencascade.js": "^2.0.0-beta.b5ff984",
    "pdf-parse": "^1.1.1",
    "pg-boss": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "pm2": "^7.0.1",
    "prisma": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "js-yaml": "^4.1.2",
    "ws": "^8.20.2"
  }
}
